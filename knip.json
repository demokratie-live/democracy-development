{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "project": ["src/**/*.ts"],
  "ignore": ["src/generated/**", "src/types/*.d.ts"],
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  },
  "ignoreDependencies": ["dotenv-cli"],
  "vitest": {
    "config": ["vitest.config.unit.ts", "vitest.config.integration.ts"],
    "entry": ["vitest.unit.setup.ts", "vitest.integration.setup.ts"]
  },
  "eslint": true,
  "prettier": true,
  "typescript": true
}
